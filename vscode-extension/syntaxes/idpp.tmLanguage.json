{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ID++",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.idpp",
          "match": "//.*$"
        },
        {
          "name": "comment.line.number-sign.idpp",
          "match": "#.*$"
        },
        {
          "name": "comment.block.idpp",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.idpp",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.idpp",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.idpp",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    "constants": {
      "name": "constant.language.idpp",
      "match": "\\b(benar|salah|kosong)\\b"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.idpp",
          "match": "\\b(jika|maka|lainnya|selesai|selama|ulangi|untuk|lakukan|buat|fungsi|jalankan|kembalikan|hentikan|lanjut|coba|tangkap|akhirnya|lempar|ekspor|ambil|kelas|baru|ini)\\b"
        },
        {
          "name": "keyword.other.idpp",
          "match": "\\b(tulis|tanya|simpan|tetap|sebagai|daftar|kamus|di|ubah|menjadi|tambahkan|ke|hapus|item|terakhir|pertama|dari)\\b"
        },
        {
          "name": "keyword.operator.idpp",
          "match": "\\b(tambah|kurang|kali|bagi|sisa|pangkat|dengan|lebih|kurang|sama|tidak|dari|dan|atau|bukan)\\b"
        }
      ]
    },
    "functions": {
      "match": "(?<=buat\\s+fungsi\\s+)([a-zA-Z_][a-zA-Z0-9_]*)",
      "name": "entity.name.function.idpp"
    },
    "variables": {
      "match": "(?<=(?:simpan|tetap)\\s+)([a-zA-Z_][a-zA-Z0-9_]*)",
      "name": "variable.other.idpp"
    }
  },
  "scopeName": "source.idpp"
}
