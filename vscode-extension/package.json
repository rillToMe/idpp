{
  "name": "idpp-language",
  "displayName": "ID++ Language Support",
  "description": "Syntax highlighting, snippets, dan dukungan bahasa untuk ID++ — bahasa pemrograman berbahasa Indonesia",
  "version": "1.0.0",
  "publisher": "idpp-team",
  "icon": "icons/idpp-light.png",
  "engines": { "vscode": "^1.74.0" },
  "categories": ["Programming Languages"],
  "keywords": ["idpp", "indonesia", "bahasa indonesia", "programming language"],
  "repository": {
    "type": "git",
    "url": "https://github.com/rillToMe/idpp"
  },
  "contributes": {
    "languages": [{
      "id": "idpp",
      "aliases": ["ID++", "idpp"],
      "extensions": [".idpp"],
      "configuration": "./language-configuration.json",
      "icon": {
        "light": "./icons/idpp-light.png",
        "dark": "./icons/idpp-dark.png"
      }
    }],
    "grammars": [{
      "language": "idpp",
      "scopeName": "source.idpp",
      "path": "./syntaxes/idpp.tmLanguage.json"
    }],
    "snippets": [{
      "language": "idpp",
      "path": "./snippets/idpp.json"
    }]
  }
}
